# Copy to .env and edit. Never commit .env.
# The non-secret tunables live in settings.toml (copy from settings.example.toml).

COMPOSE_PROJECT_NAME=plmmsa
API_HOST_PORT=8080

# Bind-mount targets on the host. Persistence lives on disk paths you
# control, so it survives container rebuilds and compose teardown.
# - MODEL_CACHE_DIR:     PLM weights + HuggingFace cache (read-only mount).
# - VDB_DATA_DIR:        FAISS indexes + id-mapping pickles (read-only mount).
# - CACHE_OPS_DATA_DIR:  cache-ops Redis — jobs, tokens, rate limits. AOF on,
#                        small working set, noeviction.
# - CACHE_SEQ_DATA_DIR:  cache-seq Redis — seq:* and tax:* lookups. Big,
#                        read-mostly, rebuildable from source FASTAs.
# - CACHE_EMB_DATA_DIR:  cache-emb Redis — PLM embedding result cache. Hot,
#                        rebuildable, LRU-evicted when capped.
# Create these paths yourself with correct ownership before `./bin/up.sh`
# so compose doesn't create them as root.
MODEL_CACHE_DIR=./model_cache
VDB_DATA_DIR=./vdb_data
CACHE_OPS_DATA_DIR=./cache_ops_data
CACHE_SEQ_DATA_DIR=./cache_seq_data
CACHE_EMB_DATA_DIR=./cache_emb_data
# Optional cap for cache-emb (bytes; 0 = unlimited; typical: 64gb-ish).
CACHE_EMB_MAXMEMORY=0
CACHE_EMB_POLICY=allkeys-lru
# cache-seq memory policy; leave at noeviction to fail writes rather than
# silently evicting loaded UniRef50 records.
CACHE_SEQ_POLICY=noeviction

# Per-PLM device pins. Both Ankh variants can share a GPU if needed.
ANKH_CL_DEVICE=cuda:0
ESM1B_DEVICE=cuda:1
PROTTRANS_DEVICE=cuda:2
ANKH_LARGE_DEVICE=cuda:3

# Number of uvicorn worker processes in the align container. Each worker
# is a separate ASGI process behind port 8083; concurrent /align/bin
# requests are served in parallel without blocking on each other's numba
# compiles. Workers fork the aligner registry — memory is roughly linear
# in the count. 4 is a good starting point; drop to 1 when debugging.
PLMMSA_ALIGN_UVICORN_WORKERS=4

# Ankh-CL checkpoint: our in-house contrastive-learning fine-tune.
# Leave blank until the checkpoint is placed under MODEL_CACHE_DIR (or the
# licensing decision from CLAUDE.md "Open-source readiness" is made).
ANKH_CL_CHECKPOINT=

# Redis-backed shard path index (keys shard:<model>:<id> → folder).
# Replaces the /gpfs-hosted sqlite index.db on the runtime path; sqlite
# stays the build-time source of truth. Populate once via
# `python -m plmmsa.tools.build_shard_index`.
PLMMSA_SHARD_INDEX_REDIS_URL=redis://cache-seq:6379/0

# Bootstrap admin token. Use ONCE to mint per-client tokens via
# `POST /admin/tokens`; after that, clients should use those minted tokens.
# Rotate this one per docs/maintenance.md. Never route `/admin/*` through
# the public Cloudflare tunnel.
# Regenerate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=change-me

# --- Cloudflare Tunnel (optional) -------------------------------------------
# Set these before running `docker compose --profile tunnel up -d`.
# Walkthrough: docs/cloudflare-tunnel.md.
#
# CLOUDFLARE_TUNNEL_TOKEN is the long `eyJ...` string Zero Trust generates
# when you create the tunnel. It is a secret — never commit it.
# CLOUDFLARE_TUNNEL_HOSTNAME is informational (the compose file does not use
# it); keep it in sync with the public hostname you configured in the CF
# dashboard so operators can see at a glance where the tunnel lands.
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_HOSTNAME=plmmsa.deepfold.org
